# Local development template for apps/api

HOST=localhost
PORT=3000
NODE_ENV=development

# JWT
ACCESS_TOKEN_SECRET=replace-me-local-access-secret
ACCESS_TOKEN_EXPIRATION=15m
REFRESH_TOKEN_SECRET=replace-me-local-refresh-secret
REFRESH_TOKEN_EXPIRATION=30d

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/nestjs

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=local-dev-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=local-dev-google-client-secret

# Mail
MAIL_HOST=smtp.ethereal.email
MAIL_PORT=587
MAIL_USERNAME=local-user@example.com
MAIL_PASSWORD=replace-me-local-mail-password
MAIL_SECURE=false

# GCS + Vertex AI
GCS_BUCKET=local-dev-bucket
GCP_PROJECT_ID=
GCP_CLIENT_EMAIL=
GCP_PRIVATE_KEY=
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# CORS + routing
ALLOWED_ORIGINS=http://localhost:3002
API_PREFIX=api

# Worker integration
WORKER_TASK_PROVIDER=http
WORKER_TASK_URL=http://localhost:4001/tasks
WORKER_AUTH_TOKEN=local-worker-token
WORKER_TASKS_PROJECT_ID=
WORKER_TASKS_LOCATION=
WORKER_TASKS_QUEUE=
WORKER_TASKS_SERVICE_ACCOUNT_EMAIL=
WORKER_TASKS_OIDC_AUDIENCE=
WORKER_CALLBACK_URL=http://localhost:3000/api/job-sources/complete
WORKER_CALLBACK_TOKEN=local-callback-token
WORKER_CALLBACK_OIDC_AUDIENCE=
WORKER_CALLBACK_OIDC_SERVICE_ACCOUNT_EMAIL=
WORKER_CALLBACK_SIGNING_SECRET=
WORKER_CALLBACK_SIGNATURE_TOLERANCE_SEC=300
WORKER_REQUEST_TIMEOUT_MS=5000
WORKER_TASK_MAX_PAYLOAD_BYTES=262144

# Health + request handling
DISK_HEALTH_THRESHOLD=0.98
API_BODY_LIMIT=1mb

# Global throttling
API_THROTTLE_TTL_MS=60000
API_THROTTLE_LIMIT=120
AUTH_LOGIN_THROTTLE_TTL_MS=60000
AUTH_LOGIN_THROTTLE_LIMIT=5
AUTH_REFRESH_THROTTLE_TTL_MS=60000
AUTH_REFRESH_THROTTLE_LIMIT=10
AUTH_REGISTER_THROTTLE_TTL_MS=60000
AUTH_REGISTER_THROTTLE_LIMIT=3
AUTH_OTP_THROTTLE_TTL_MS=60000
AUTH_OTP_THROTTLE_LIMIT=3

# Scrape + diagnostics tuning
SCRAPE_DB_REUSE_HOURS=24
SCRAPE_MAX_ACTIVE_RUNS_PER_USER=2
SCRAPE_DAILY_ENQUEUE_LIMIT_PER_USER=40
SCRAPE_ENQUEUE_IDEMPOTENCY_TTL_SEC=30
SCRAPE_MAX_RETRY_CHAIN_DEPTH=5
SCRAPE_STALE_PENDING_MINUTES=15
SCRAPE_STALE_RUNNING_MINUTES=60
JOB_SOURCE_DIAGNOSTICS_WINDOW_HOURS=72
DOCUMENT_DIAGNOSTICS_WINDOW_HOURS=168

# Scheduler + ops
SCHEDULER_AUTH_TOKEN=local-scheduler-token
SCHEDULER_TRIGGER_BATCH_SIZE=20
OPS_INTERNAL_TOKEN=local-ops-token

# Auto scoring
AUTO_SCORE_ON_INGEST=true
AUTO_SCORE_CONCURRENCY=1
AUTO_SCORE_MIN_SCORE=0
AUTO_SCORE_RETRY_ATTEMPTS=2

# Notebook ranking
NOTEBOOK_APPROX_VIOLATION_PENALTY=10
NOTEBOOK_APPROX_MAX_VIOLATION_PENALTY=30
NOTEBOOK_APPROX_SCORED_BONUS=10
NOTEBOOK_EXPLORE_UNSCORED_BASE=0
NOTEBOOK_EXPLORE_RECENCY_WEIGHT=5
WORKSPACE_SUMMARY_CACHE_TTL_SEC=0
