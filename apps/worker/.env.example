# Local development template for apps/worker

NODE_ENV=development
WORKER_ALLOWED_ORIGINS=http://localhost:3002
WORKER_LOG_LEVEL=info
WORKER_PORT=4001
QUEUE_PROVIDER=local

# Queue / auth
TASKS_AUTH_TOKEN=local-worker-token
TASKS_PROJECT_ID=
TASKS_LOCATION=
TASKS_QUEUE=
TASKS_URL=
TASKS_SERVICE_ACCOUNT_EMAIL=
TASKS_OIDC_AUDIENCE=

# Worker -> API callback
WORKER_CALLBACK_URL=http://localhost:3000/api/job-sources/complete
WORKER_CALLBACK_TOKEN=local-callback-token
WORKER_CALLBACK_OIDC_AUDIENCE=
WORKER_CALLBACK_SIGNING_SECRET=
WORKER_CALLBACK_RETRY_ATTEMPTS=3
WORKER_CALLBACK_RETRY_BACKOFF_MS=1000
WORKER_CALLBACK_RETRY_MAX_DELAY_MS=10000
WORKER_CALLBACK_RETRY_JITTER_PCT=0.2
WORKER_HEARTBEAT_INTERVAL_MS=10000

# Request + body limits
WORKER_MAX_BODY_BYTES=262144
WORKER_MAX_CONCURRENT_TASKS=1
WORKER_MAX_QUEUE_SIZE=100
WORKER_TASK_TIMEOUT_MS=180000
WORKER_SMOKE_ACCEPT_ONLY=false

# Browser / scraping behavior
PLAYWRIGHT_HEADLESS=false
PRACUJ_LISTING_URL=https://it.pracuj.pl/praca?wm=home-office%2Chybrid%2Cfull-office&its=frontend
PRACUJ_LISTING_LIMIT=10
PRACUJ_LISTING_DELAY_MS=1500
PRACUJ_LISTING_COOLDOWN_MS=0
PRACUJ_DETAIL_DELAY_MS=2000
PRACUJ_DETAIL_CACHE_HOURS=24
PRACUJ_DETAIL_HUMANIZE=true
PRACUJ_DETAIL_COOKIES_PATH=pracuj-pl-cookies.json
PRACUJ_REQUIRE_DETAIL=false
PRACUJ_PROFILE_DIR=

# Output / dead letters
WORKER_OUTPUT_DIR=data
WORKER_OUTPUT_MODE=minimal
WORKER_DEAD_LETTER_DIR=data/dead-letter

# Optional DB usage
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/nestjs
