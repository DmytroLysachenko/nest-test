{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": ["CI", "DATABASE_URL", "PORT", "SUPPORT_CONFIG_PATH", "SystemDrive", "CATALOG_BACKFILL_BATCH_SIZE", "NEXT_PHASE"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "NODE_ENV",
        "DATABASE_URL",
        "PORT",
        "SystemDrive",
        "API_READ_THROTTLE_TTL_MS",
        "API_READ_THROTTLE_LIMIT",
        "API_WRITE_THROTTLE_TTL_MS",
        "API_WRITE_THROTTLE_LIMIT",
        "API_AUTH_THROTTLE_TTL_MS",
        "API_AUTH_THROTTLE_LIMIT",
        "API_SENSITIVE_THROTTLE_TTL_MS",
        "API_SENSITIVE_THROTTLE_LIMIT"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
