{
  "name": "NestJS Boilerplate",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@nestjs/cli": "^11.0.7",
    "@repo/lint-config": "workspace:*",
    "@repo/ts-config": "workspace:*",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jiti": "^2.4.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "syncpack": "14.0.0-alpha.12",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.11.0",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core"
    ],
    "overrides": {
      "fast-xml-parser": "^4.5.4",
      "multer": "^2.1.1",
      "tar": "^7.5.10",
      "axios": "^1.13.6",
      "validator": "^13.15.22",
      "minimatch": "^10.2.3",
      "rollup": "^4.59.0",
      "serialize-javascript": "^7.0.3",
      "form-data": "^4.0.4",
      "basic-ftp": "^5.2.0"
    }
  },
  "scripts": {
    "build": "turbo run build --log-order=grouped",
    "check-types": "turbo run check-types",
    "dev:stack": "turbo run dev --filter=api --filter=worker --filter=web",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "verify:prepush": "pnpm --filter web check-types && pnpm --filter api test -- --runInBand src/features/auth/auth.service.spec.ts src/config/env.spec.ts && pnpm --filter worker test && pnpm --filter api build && pnpm --filter worker build",
    "smoke:e2e": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke-e2e.ps1",
    "start": "pnpm dev:stack",
    "start:all": "turbo run start"
  }
}
